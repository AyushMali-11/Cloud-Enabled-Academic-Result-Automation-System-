# Option A: Supabase (recommended for cloud)
# Copy connection string from Supabase -> Project Settings -> Database
# Use Session pooler URI; # in password must be encoded as %23
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
SECRET_KEY=change-this-to-a-random-secret-key

# Option B: Local PostgreSQL
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=academic_results
# SECRET_KEY=change-this-to-a-random-secret-key
